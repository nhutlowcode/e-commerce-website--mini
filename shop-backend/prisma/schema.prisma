generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  description String
  price       Int
  image       String
  stock       Int         @default(0) // 👉 THÊM DÒNG NÀY (Mặc định kho = 0)
  createdAt   DateTime @default(now())

  // 👉 THÊM ĐÚNG DÒNG NÀY VÀO CUỐI MODEL PRODUCT:
  orderItems  OrderItem[]
  cartItems CartItem[]
}

// Định nghĩa các vai trò trong hệ thống
enum Role {
  USER
  ADMIN
}

// Bảng lưu trữ thông tin người dùng
// Bảng lưu trữ thông tin người dùng
model User {
  id                  Int       @id @default(autoincrement())
  email               String    @unique                  
  password            String?   // 🔴 Thêm dấu ? (Bắt buộc cho Google Login)                 
  name                String?                             
  avatar              String?   // 🔴 Thêm cột này để hứng ảnh từ Google
  authProvider        String    @default("local") // 🔴 Phân biệt 'local' hay 'google'
  
  // 🔴 2 Cột phục vụ cho tính năng Quên mật khẩu
  resetPasswordToken  String?   // Lưu mã xác nhận
  resetPasswordExpires DateTime? // Lưu thời gian hết hạn của mã

  role                Role      @default(USER)           
  createdAt           DateTime  @default(now())          
  updatedAt           DateTime  @updatedAt               
  sessions            Session[] 

  orders              Order[]
  cart                Cart?
}

// Bảng quản lý phiên đăng nhập và Refresh Token
model Session {
  id        Int      @id @default(autoincrement())
  token     String   @unique                  // Lưu chuỗi Refresh Token
  userId    Int                               // ID của người dùng sở hữu phiên này
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade) // Tự động xóa session nếu user bị xóa
  userAgent String?                           // Lưu thông tin trình duyệt/thiết bị để quản lý
  expiresAt DateTime                          // Ngày hết hạn của Refresh Token này
  createdAt DateTime @default(now())
}

// 1. Định nghĩa các trạng thái của đơn hàng
enum OrderStatus {
  PENDING     // Chờ thanh toán / Chờ xử lý
  PAID        // Đã thanh toán trực tuyến thành công
  SHIPPING    // Đang giao hàng
  DELIVERED   // Đã giao thành công
  CANCELLED   // Đã hủy đơn
}

// 2. Bảng Đơn hàng tổng
model Order {
  id          String      @id @default(uuid()) // Giữ String UUID để mã đơn hàng phức tạp, bảo mật hơn số tăng dần
  userId      Int?        // Đổi thành Int? để khớp với User.id (để trống nếu khách không đăng nhập)
  user        User?       @relation(fields: [userId], references: [id])
  
  name        String      // Tên người nhận hàng
  phone       String      // Số điện thoại nhận hàng
  address     String      // Địa chỉ giao hàng
  
  totalAmount Int         // Đổi thành Int để khớp với Product.price
  status      OrderStatus @default(PENDING)
  
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  items       OrderItem[]
}

// 3. Bảng Chi tiết từng món hàng trong đơn
model OrderItem {
  id        Int      @id @default(autoincrement()) // Dùng Int tăng dần cho gọn
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  productId Int      // Đổi thành Int để khớp với Product.id
  product   Product  @relation(fields: [productId], references: [id])
  
  quantity  Int      // Số lượng mua
  price     Int      // Đổi thành Int để khớp với Product.price (Lưu giá tại thời điểm mua)
}

// 👉 1. BẢNG CART (Đại diện cho cái giỏ của mỗi User)
model Cart {
  id        Int        @id @default(autoincrement())
  
  // Ràng buộc @unique đảm bảo 1 tài khoản chỉ có ĐÚNG 1 cái giỏ hàng tồn tại song song
  userId    Int        @unique 
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

// 👉 2. BẢNG CART ITEM (Chi tiết từng món trong giỏ)
model CartItem {
  id        Int      @id @default(autoincrement())
  
  cartId    Int
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  
  productId Int
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  quantity  Int      @default(1) // Mặc định thêm vào giỏ là 1 cái

  // CÚ CHỐT BẢO MẬT: Đảm bảo trong 1 giỏ hàng, 1 mã sản phẩm chỉ xuất hiện 1 dòng duy nhất.
  // Nếu khách bấm thêm món đó lần 2, hệ thống sẽ tự động bắt lỗi và báo cho Backend biết để "Cộng dồn số lượng" thay vì đẻ ra dòng mới.
  @@unique([cartId, productId]) 
}